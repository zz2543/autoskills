# Copy this file to `.env` and fill in only the providers you actually use.

MINIMAX_API_KEY=replace-with-rotated-key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
QWEN_API_KEY=

# MiniMax is treated as an OpenAI-compatible backend by default.
# International users typically use https://api.minimax.io/v1
# Users in China typically use https://api.minimaxi.com/v1
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.1
